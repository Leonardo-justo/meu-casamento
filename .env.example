# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# =========================
# Pagamentos / InfinitePay
# =========================
# Modos: mock | pix_manual | infinitepay
PAYMENT_MODE="mock"

# URL pública da aplicação para retorno e webhook
APP_BASE_URL="http://localhost:3000"

# InfinitePay API
INFINITEPAY_API_BASE_URL="https://api.infinitepay.io"
INFINITEPAY_CREATE_PATH="/v1/payments"
INFINITEPAY_API_TOKEN=""

# Segurança do webhook (HMAC SHA256)
INFINITEPAY_WEBHOOK_SECRET=""
ALLOW_INSECURE_WEBHOOK="true"

# Fallback PIX manual (quando PAYMENT_MODE=pix_manual)
PIX_PAYMENT_URL=""
PIX_COPY_PASTE_CODE=""

# Seed local opcional
ENABLE_DATA_SEED="false"
